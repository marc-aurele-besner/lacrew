# Contracts / deploy
HUMAN_ROOT=
# First public testnet (Ethereum Sepolia)
SEPOLIA_RPC_URL=
# Optional later Base Sepolia slot
BASE_SEPOLIA_RPC_URL=
BASE_RPC_URL=
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
PRIVATE_KEY=

# Local Anvil (indexer / onchain CLI). Start with: anvil
ANVIL_RPC=http://127.0.0.1:8545
CHAIN_ID=31337
INDEXER_PATH=.lacrew/indexer.json

# Anvil account #1 — signs EscalationRouter.resolve as manager (DeployMockOrg on 31337).
# DEMO ONLY — never use on mainnet / funded networks.
MANAGER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# Optional override; defaults to Anvil #1 on chain 31337.
# MANAGER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Postgres (Neon connection string, or local Docker — see docker-compose.yml)
# docker compose up -d
# DATABASE_URL=postgres://lacrew:lacrew@localhost:5432/lacrew
DATABASE_URL=

# Orchestrator
PORT=8788
# Optional pg-boss cron (when DATABASE_URL set). Default: hourly epoch.
# EPOCH_CRON=0 * * * *
