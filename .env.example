# Contracts / deploy
HUMAN_ROOT=
# First public testnet (Ethereum Sepolia)
SEPOLIA_RPC_URL=
# Optional later Base Sepolia slot
BASE_SEPOLIA_RPC_URL=
BASE_RPC_URL=
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
# Anvil account #0 — deploys DeployMockOrg, signs proposals, sponsors session gas.
# The orchestrator runs onchain only when this and ANVIL_RPC are both set; leaving
# it empty is what used to drop the whole stack into fabricated data.
# DEMO ONLY — never use on mainnet / funded networks. Replace for any real chain.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Local Anvil (indexer / onchain CLI). Start the whole stack with: pnpm dev:stack
ANVIL_RPC=http://127.0.0.1:8545
CHAIN_ID=31337
# Relative paths resolve against the workspace root, not the running process's
# cwd — the indexer writes this file and the orchestrator reads it from a
# different directory.
INDEXER_PATH=.lacrew/indexer.json

# Anvil account #1 — signs EscalationRouter.resolve as manager (DeployMockOrg on 31337).
# DEMO ONLY — never use on mainnet / funded networks.
MANAGER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
# Optional override; defaults to Anvil #1 on chain 31337.
# MANAGER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Postgres (Neon connection string, or local Docker — see docker-compose.yml)
# docker compose up -d
# DATABASE_URL=postgres://lacrew:lacrew@localhost:5432/lacrew
DATABASE_URL=

# Orchestrator
PORT=8788
# Require "Authorization: Bearer <token>" on all orchestrator routes except GET /health.
# Unset = open (localhost demos only). lacrew.xyz API + examples read the same env.
# LACREW_ORCH_TOKEN=
# Seals session private keys at rest so a restart reuses the live onchain
# session instead of issuing (and gas-funding) a replacement. Unset is
# supported: sessions simply do not survive a restart. 32 bytes, base64 —
# generate with: openssl rand -base64 32
LACREW_SESSION_KEY=
# Tried on decrypt only, so the key above can be rotated without downtime.
# LACREW_SESSION_KEY_PREVIOUS=
# ETH topped up to a session key, and only when it is short. Default 0.01.
# SESSION_GAS_STIPEND_ETH=0.01

# pg-boss cron when DATABASE_URL is set (default hourly). Surfaced on GET /epoch + /health.
# EPOCH_CRON=0 * * * *
# Memory-queue interval (ms) when DATABASE_URL is unset. Opt-in; 0/unset = POST /epoch only.
# EPOCH_INTERVAL_MS=3600000

# Model provider (F1.7) — Memory stub when unset; OpenRouter HTTP when set
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/auto
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

