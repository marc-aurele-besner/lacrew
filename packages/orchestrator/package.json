{
  "name": "@lacrew/orchestrator",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/runtime.test.ts",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lacrew/core": "workspace:*",
    "@lacrew/sdk": "workspace:*",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
