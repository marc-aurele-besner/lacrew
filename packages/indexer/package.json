{
  "name": "@lacrew/indexer",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/store.test.ts src/watcher.test.ts src/sinks/sinks.test.ts"
  },
  "dependencies": {
    "@lacrew/core": "workspace:*",
    "@lacrew/db": "workspace:*",
    "viem": "^2.31.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
