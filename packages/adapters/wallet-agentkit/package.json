{
  "name": "@lacrew/adapter-wallet-agentkit",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/index.test.ts",
    "clean": "rm -rf dist",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json",
    "smoke:cdp": "node --import tsx scripts/smoke-cdp.ts"
  },
  "dependencies": {
    "@lacrew/core": "workspace:*"
  },
  "devDependencies": {
    "@coinbase/cdp-sdk": "^1.54.0",
    "@types/node": "^26.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@coinbase/cdp-sdk": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@coinbase/cdp-sdk": {
      "optional": true
    }
  }
}
