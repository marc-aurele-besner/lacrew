{
  "name": "lacrew",
  "private": true,
  "version": "0.0.0",
  "description": "LaCrew — payroll, budgets, and approvals for AI agent teams",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@lacrew/orchestrator",
    "dev:indexer": "pnpm --filter @lacrew/indexer dev",
    "dev:all": "turbo run dev --filter=@lacrew/orchestrator --filter=@lacrew/indexer",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
